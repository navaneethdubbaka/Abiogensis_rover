# Example environment for the PC GPU follow server (pc_follow_server.py)
# Copy to a file such as `.env` in the project root, then load before starting:
#   PowerShell:  Get-Content .env | ForEach-Object { if ($_ -match '^([^#][^=]+)=(.*)$') { Set-Item "env:$($matches[1])" $matches[2].Trim() } }
#   bash:        set -a && source .env && set +a
# Or set variables in your system / IDE run configuration.
#
# Start server:
#   uvicorn pc_follow_server:app --host 0.0.0.0 --port 8765
#   python pc_follow_server.py

# --- Server bind (used only when running: python pc_follow_server.py) ---
FOLLOW_SERVER_HOST=0.0.0.0
FOLLOW_SERVER_PORT=8765

# --- YOLO model ---
# Path to .pt weights; if unset, searches yolo26n.pt next to this repo
YOLO_MODEL_PATH=

# Inference: square size (smaller = faster, e.g. 320, 416, 640)
ROBOT_YOLO_IMGSZ=320
# CUDA GPU index (e.g. 0) or "cpu"; leave empty for Ultralytics auto-detect
ROBOT_YOLO_DEVICE=0
# 1 = FP16 on GPU (faster on supported cards)
ROBOT_YOLO_HALF=1
# COCO person = 0; use "all" to disable class filter at NMS (still filtered by name in policy)
ROBOT_YOLO_CLASSES=0
# Detection confidence passed into Ultralytics (also used in follow policy min_confidence below)
MIN_CONFIDENCE=0.4

# --- Tracking ---
# 1 = ByteTrack (bytetrack.yaml); falls back to predict if tracker fails
ROBOT_USE_TRACKER=1
ROBOT_TRACKER=bytetrack.yaml

# --- Follow policy (same semantics as human_following.py) ---
TARGET_CLASS=person
FORWARD_SPEED=150
TURN_SPEED_MIN=115
TURN_SPEED_MAX=200
CENTER_TOLERANCE=0.05
# Hysteresis: start turning only when |x_dev| exceeds this (default = max(CENTER*2.2, 0.09) if unset)
TURN_ENTER_TOLERANCE=
# Softer steering: lower = slower turns (try 220–320 for Pi+network setups)
ALIGN_TURN_GAIN=400
# Seconds to wait before flipping L<->R; reduces rapid zig-zag (try 0.12–0.25)
TURN_DIRECTION_DEBOUNCE_SEC=0
STOP_AREA_RATIO=0.35
LOST_FRAMES_BEFORE_SEARCH=20
SEARCH_TURN_DURATION=0.25
SEARCH_ALTERNATE_EVERY=3
# Lower = smoother x error (e.g. 0.22 for WiFi / remote inference; default 0.35)
X_DEV_SMOOTH_ALPHA=0.35
# 0 = continuous turn; >0 = duty-cycle pulse (seconds on / same off)
TURN_PULSE_SEC=0
