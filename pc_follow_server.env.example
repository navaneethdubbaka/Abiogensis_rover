# Example environment for the PC GPU follow server (pc_follow_server.py)
# Copy to a file such as `.env` in the project root.
# pc_follow_server loads `.env` automatically via python-dotenv. You can still export vars in the shell if you prefer.
#
# Start server:
#   uvicorn pc_follow_server:app --host 0.0.0.0 --port 8765
#   python pc_follow_server.py

# --- Server bind (used only when running: python pc_follow_server.py) ---
FOLLOW_SERVER_HOST=0.0.0.0
FOLLOW_SERVER_PORT=8765

# --- Inference backend ---
# yolo = Ultralytics + follow_policy (default). vlm = Ollama vision model (no YOLO load).
PC_FOLLOW_MODE=yolo

# --- Ollama VLM (only when PC_FOLLOW_MODE=vlm) ---
# Ollama must be running locally or on the LAN; model must support images (e.g. gemma4:e2b, qwen3.5:0.8b).
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Example edge model: gemma4:e2b  →  ollama pull gemma4:e2b
OLLAMA_VLM_MODEL=
# Ollama /api/chat: false = no thinking step (default; faster). Gemma 4: also avoid <|think|> at the start of VLM_SYSTEM_PROMPT.
VLM_OLLAMA_THINK=0
OLLAMA_TIMEOUT_SEC=120
# Natural-language mission (used if neither VLM_SYSTEM_PROMPT nor VLM_SYSTEM_PROMPT_FILE is set)
# Avoid "stop if unsure" — small VLMs then emit S:0 every frame. Prefer search behavior:
VLM_TASK=Follow the person in view; avoid collisions. If you do not see them, turn slowly (L or R) or creep forward to search; only stop for real hazards.
# Optional: full system prompt in .env (if non-empty, used as-is; wins over VLM_SYSTEM_PROMPT_FILE)
# For multiline prompts, prefer a file — see VLM_SYSTEM_PROMPT_FILE.
VLM_SYSTEM_PROMPT=
# Optional: path to UTF-8 file with full system prompt (used only if VLM_SYSTEM_PROMPT is empty)
# Example:  VLM_SYSTEM_PROMPT_FILE=/home/you/rover_vlm_system.txt
VLM_SYSTEM_PROMPT_FILE=
# 1 = print each Ollama assistant reply to the PC server terminal (default on)
VLM_PRINT_RESPONSE=1
# Max chars of assistant text per log (0 = no truncation). Default 8000.
VLM_LOG_RESPONSE_MAX_CHARS=8000
# 1 = on server startup, print the effective system prompt once (default on in vlm mode)
VLM_LOG_SYSTEM_PROMPT_AT_START=1
# Clamp motor command values (F/L/R/B speeds)
VLM_MIN_TURN=115
VLM_MAX_TURN=200
VLM_MAX_FORWARD=200
VLM_MAX_BACK=200
# 1 = include previous validated cmd in the user message (continuity without chat history)
VLM_INCLUDE_LAST_CMD=0

# --- YOLO model ---
# Path to .pt weights; if unset, searches yolo26n.pt next to this repo
YOLO_MODEL_PATH=

# Inference: square size (smaller = faster, e.g. 320, 416, 640)
ROBOT_YOLO_IMGSZ=320
# CUDA GPU index (e.g. 0), "cuda:0", or "cpu". Empty = Ultralytics auto.
# Requires a CUDA-enabled PyTorch build. If `pip show torch` shows +cpu, install GPU torch from
# https://pytorch.org/get-started/locally/ — otherwise the server falls back to CPU (see /health).
ROBOT_YOLO_DEVICE=0
# 1 = FP16 on GPU (ignored when running on CPU)
ROBOT_YOLO_HALF=1
# COCO person = 0; use "all" to disable class filter at NMS (still filtered by name in policy)
ROBOT_YOLO_CLASSES=0
# Detection confidence passed into Ultralytics (also used in follow policy min_confidence below)
MIN_CONFIDENCE=0.4

# --- Tracking ---
# 1 = ByteTrack (bytetrack.yaml); falls back to predict if tracker fails
ROBOT_USE_TRACKER=1
ROBOT_TRACKER=bytetrack.yaml

# --- Follow policy (same semantics as human_following.py) ---
TARGET_CLASS=person
FORWARD_SPEED=150
TURN_SPEED_MIN=115
TURN_SPEED_MAX=200
CENTER_TOLERANCE=0.05
# Hysteresis: start turning only when |x_dev| exceeds this (default = max(CENTER*2.2, 0.09) if unset)
TURN_ENTER_TOLERANCE=
# Softer steering: lower = slower turns (try 220–320 for Pi+network setups)
ALIGN_TURN_GAIN=400
# Seconds to wait before flipping L<->R; reduces rapid zig-zag (try 0.12–0.25)
TURN_DIRECTION_DEBOUNCE_SEC=0
STOP_AREA_RATIO=0.35
LOST_FRAMES_BEFORE_SEARCH=20
SEARCH_TURN_DURATION=0.25
SEARCH_ALTERNATE_EVERY=3
# Lower = smoother x error (e.g. 0.22 for WiFi / remote inference; default 0.35)
X_DEV_SMOOTH_ALPHA=0.35
# 0 = continuous turn; >0 = duty-cycle pulse (seconds on / same off)
TURN_PULSE_SEC=0
