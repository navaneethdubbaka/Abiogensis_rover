# --- PC (safety server) — copy to repo root `.env` or export in shell ---
# Run:  python -m safety_monitor.main

SAFETY_SERVER_HOST=0.0.0.0
SAFETY_SERVER_PORT=8766

# Optional shared secret; Pi must send header X-Safety-Token with the same value
SAFETY_INGEST_SECRET=

# Ollama on this PC (GPU)
OLLAMA_BASE_URL=http://127.0.0.1:11434
SAFETY_VLM_MODEL=
OLLAMA_TIMEOUT_SEC=120
# 1 = thinking models (slower)
SAFETY_OLLAMA_THINK=0

# Resize before sending to the model
SAFETY_MAX_IMAGE_SIDE=896
SAFETY_JPEG_QUALITY=85

# Static-scene gate (skip VLM when little changes for K consecutive frames)
SKIP_VLM_ON_STATIC=1
SAFETY_STATIC_DIFF_THRESHOLD=4.0
SAFETY_STATIC_FRAMES_K=3
SAFETY_MEMORY_MAX=8
SAFETY_GATE_WIDTH=160
SAFETY_GATE_HEIGHT=90

# Optional YAML overlay (merged with env); see safety_monitor/rules.example.yaml
SAFETY_CONFIG_YAML=
SAFETY_SYSTEM_PROMPT_FILE=
SAFETY_RULES_FILE=

# Telegram (PC only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML

NOTIFY_ON_SAFE=0
NOTIFY_ON_WARNING=1
NOTIFY_ON_CRITICAL=1
SAFETY_WARNING_DEBOUNCE_SEC=300

# Optional Home Assistant / n8n
SAFETY_WEBHOOK_URL=

SAFETY_LOG_DIR=logs
SAFETY_LOG_MAX_BYTES=10485760
SAFETY_LOG_BACKUP_COUNT=5

# 1 = log events but do not send Telegram/webhook
SAFETY_DRY_RUN=0

# Optional: also capture from USB cameras attached to the PC (comma-separated indices)
SAFETY_LOCAL_CAMERA_INDICES=
SAFETY_LOCAL_INTERVAL_SEC=7.5

# --- Pi only (safety_pi_sender.py) — use a separate .env on the Pi if you like ---
# SAFETY_PC_BASE_URL=http://192.168.1.50:8766
# SAFETY_CAMERA_ID=pi_cam
# SAFETY_UPLOAD_INTERVAL_SEC=7.5
# SAFETY_HTTP_TIMEOUT=15.0
# CAMERA_INDEX=0
# FRAME_W=640
# FRAME_H=480
# JPEG_QUALITY=80
# SAFETY_INGEST_TOKEN=   # same as PC SAFETY_INGEST_SECRET
